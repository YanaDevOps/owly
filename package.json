{
  "name": "owly",
  "version": "1.3.0",
  "description": "Focused WebRTC communication platform",
  "author": "YanaDevOps (https://github.com/YanaDevOps)",
  "homepage": "https://github.com/YanaDevOps/owly",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YanaDevOps/owly.git"
  },
  "scripts": {
    "lint": "eslint static/*.js",
    "lint:fix": "eslint static/*.js --fix",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "node scripts/run-frontend-tests.mjs",
    "test:backend": "node scripts/run-go-tests.mjs",
    "test:smoke": "playwright test",
    "test:security": "node scripts/run-security-checks.mjs",
    "test:security:audit": "npm audit --audit-level=high",
    "test:full": "npm run test && npm run test:security && npm run test:smoke"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^9.18.0",
    "globals": "^15.14.0"
  },
  "type": "module"
}
